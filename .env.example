# ============================================================
# 環境変数定義サンプル
# このファイルをコピーして .env を作成してください
# .env は絶対にGitにコミットしないこと
# ============================================================

# --- Supabase ---
# Supabase ダッシュボード > Project Settings > API で確認
# [必須] プロジェクトURL（例: https://xxxx.supabase.co）
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# [必須] anon/public キー（クライアント公開用・service_role キーは絶対に使わない）
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Claude API ---
# [任意] AI 機能を使う場合のみ。Anthropic コンソールで発行
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- 通知 ---
# [任意] Slack 通知を使う場合のみ設定（Slack アプリ設定 > Incoming Webhooks）
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx

# --- GitHub（CI/CDで使用） ---
# [不要] GITHUB_TOKEN は GitHub Actions が自動提供するためここには書かない
# [注意] その他の GitHub 関連シークレットは GitHub リポジトリ Settings > Secrets で登録すること
