# ============================================================
# 環境変数定義サンプル
# このファイルをコピーして .env を作成してください
# .env は絶対にGitにコミットしないこと
# ============================================================

# --- アプリケーション基本設定 ---
# [必須] アプリの動作環境（development / staging / production）
APP_ENV=development
# [必須] アプリが待ち受けるポート番号
APP_PORT=3000
# [必須] セッション暗号化などに使うランダム文字列（openssl rand -hex 32 で生成）
APP_SECRET_KEY=your-secret-key-here

# --- Claude API ---
# [必須] Anthropic コンソール ( https://console.anthropic.com/settings/keys ) で発行
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- GCP設定 ---
# [必須] GCP プロジェクトID（GCP コンソール > プロジェクト情報で確認）
GCP_PROJECT_ID=your-gcp-project-id
# [必須] デプロイ先リージョン（東京: asia-northeast1）
GCP_REGION=asia-northeast1
# [必須] サービスアカウントキーのパス（docs/secrets-management.md 参照）
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# --- データベース ---
# [必須] 使用するDBに合わせていずれか1行のコメントを外す
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# DATABASE_URL=mysql://user:password@localhost:3306/dbname

# --- 通知 ---
# [任意] Slack 通知を使う場合のみ設定（Slack アプリ設定 > Incoming Webhooks）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx

# --- GitHub（CI/CDで使用） ---
# [不要] GITHUB_TOKEN は GitHub Actions が自動提供するためここには書かない
# [注意] その他の GitHub 関連シークレットは GitHub リポジトリ Settings > Secrets で登録すること
#        docs/secrets-management.md 参照
