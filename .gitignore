# ============================================================
# .gitignore - バージョン管理除外ファイル定義
# ============================================================

# --- 環境変数・シークレット（絶対にコミットしない） ---
.env
.env.local
.env.*.local
credentials/
*.pem
*.key
*.p12
gcp-service-account*.json

# --- 依存パッケージ ---
node_modules/
__pycache__/
*.py[cod]
.venv/
venv/
.pip/

# --- ビルド成果物 ---
dist/
build/
out/
.next/
.nuxt/

# --- IDE・エディタ ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- テスト・カバレッジ ---
coverage/
.coverage
*.lcov
.nyc_output/

# --- ログ ---
*.log
logs/
npm-debug.log*
yarn-debug.log*

# --- キャッシュ ---
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# --- GCP関連 ---
.gcloudignore
terraform.tfstate
terraform.tfstate.backup
.terraform/

# --- Expo ---
.expo/
expo-env.d.ts
*.jks
*.p8
*.mobileprovision
web-build/
